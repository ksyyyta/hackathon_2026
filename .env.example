# Публичный URL приложения (для ссылок на тесты в письмах/копировании)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Клиент API. По умолчанию — встроенные route handlers Next.js:
#   NEXT_PUBLIC_API_URL=/api
# Внешний FastAPI — укажите полный URL с суффиксом /api (иначе вход/регистрация не найдут маршруты):
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
NEXT_PUBLIC_API_URL=/api
# Куда проксировать /api при `npm run dev` (Docker frontend: http://backend:8000 через build-arg)
# API_INTERNAL_URL=http://127.0.0.1:8000

# Секреты JWT (в продакшене задайте длинные случайные строки)
JWT_SECRET=change-me-in-production
# Если не задан — используется JWT_SECRET
# JWT_REFRESH_SECRET=
